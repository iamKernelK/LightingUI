                    TweenService:Create(BindBtn, TweenInfo.new(0.2), {BackgroundColor3 = Theme.StrokeColor, TextColor3 = Theme.TextColor}):Play()
                elseif not processed and input.KeyCode == currentKey and not waitingForInput then
                    Callback(currentKey)
                end
