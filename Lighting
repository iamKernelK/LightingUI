        function TabData:CreateDropdown(DropOptions)
            local DropName = DropOptions.Name or "Dropdown"
            local DropList = DropOptions.Options or {}
            local MaxSelect = DropOptions.Max or 1 -- إذا كان "Unlimited" نتعامل معها كـ math.huge
            if type(MaxSelect) == "string" and string.lower(MaxSelect) == "unlimited" then
                MaxSelect = math.huge
            end
            local Callback = DropOptions.Callback or function() end

            local SelectedItems = {}

            -- زر الـ Dropdown الأساسي في القائمة
            local DropBtn = Instance.new("TextButton", TabContainer)
            DropBtn.Size = UDim2.new(1, 0, 0, 40)
            DropBtn.BackgroundColor3 = Theme.ElementBackground
            DropBtn.BackgroundTransparency = 0.3
            DropBtn.Text = ""
            DropBtn.AutoButtonColor = false
            Instance.new("UICorner", DropBtn).CornerRadius = UDim.new(0, 8)
            Instance.new("UIStroke", DropBtn).Color = Theme.StrokeColor
            Instance.new("UIStroke", DropBtn).Transparency = 0.5

            local DropLabel = Instance.new("TextLabel", DropBtn)
            DropLabel.Size = UDim2.new(1, -120, 1, 0)
            DropLabel.Position = UDim2.new(0, 15, 0, 0)
            DropLabel.BackgroundTransparency = 1
            DropLabel.Text = DropName
            DropLabel.TextColor3 = Theme.TextColor
            DropLabel.Font = Enum.Font.GothamMedium
            DropLabel.TextSize = 13
            DropLabel.TextXAlignment = Enum.TextXAlignment.Left

            local SelectedDisplay = Instance.new("TextLabel", DropBtn)
            SelectedDisplay.Size = UDim2.new(0, 80, 1, 0)
            SelectedDisplay.Position = UDim2.new(1, -100, 0, 0)
            SelectedDisplay.BackgroundTransparency = 1
            SelectedDisplay.Text = "None"
            SelectedDisplay.TextColor3 = Theme.AccentColor
            SelectedDisplay.Font = Enum.Font.GothamMedium
            SelectedDisplay.TextSize = 12
            SelectedDisplay.TextXAlignment = Enum.TextXAlignment.Right
            SelectedDisplay.TextTruncate = Enum.TextTruncate.AtEnd

            local DropArrow = Instance.new("ImageLabel", DropBtn)
            DropArrow.Size = UDim2.new(0, 14, 0, 14)
            DropArrow.Position = UDim2.new(1, -20, 0.5, 0)
            DropArrow.AnchorPoint = Vector2.new(0, 0.5)
            DropArrow.BackgroundTransparency = 1
            DropArrow.Image = "rbxassetid://10392248278"
            DropArrow.ImageColor3 = Theme.TextMuted

            -- ====================
            -- واجهة القائمة العائمة (Overlay ZIndex عالي)
            -- ====================
            local OverlayFrame = Instance.new("Frame", ScreenGui) -- توضع في الـ ScreenGui لتخطي الـ ClipsDescendants
            OverlayFrame.Size = UDim2.new(0, 220, 0, 200)
            OverlayFrame.BackgroundColor3 = Theme.DropdownBackground
            OverlayFrame.Visible = false
            OverlayFrame.ZIndex = 100
            Instance.new("UICorner", OverlayFrame).CornerRadius = UDim.new(0, 8)
            local OverlayStroke = Instance.new("UIStroke", OverlayFrame)
            OverlayStroke.Color = Theme.StrokeColor
            OverlayStroke.Thickness = 1.5
            
            -- إضافة ظل للقائمة العائمة
            local OverlayShadow = Shadow:Clone()
            OverlayShadow.Parent = OverlayFrame

            -- شريط البحث نحيف وأنيق
            local SearchBox = Instance.new("TextBox", OverlayFrame)
            SearchBox.Size = UDim2.new(1, -20, 0, 30)
            SearchBox.Position = UDim2.new(0, 10, 0, 10)
            SearchBox.BackgroundColor3 = Theme.ElementBackground
            SearchBox.Text = ""
            SearchBox.PlaceholderText = "Search..."
            SearchBox.TextColor3 = Theme.TextColor
            SearchBox.Font = Enum.Font.GothamMedium
            SearchBox.TextSize = 12
            SearchBox.ZIndex = 101
            Instance.new("UICorner", SearchBox).CornerRadius = UDim.new(0, 6)
            Instance.new("UIStroke", SearchBox).Color = Theme.StrokeColor

            local ItemScroll = Instance.new("ScrollingFrame", OverlayFrame)
            ItemScroll.Size = UDim2.new(1, -10, 1, -50)
            ItemScroll.Position = UDim2.new(0, 5, 0, 45)
            ItemScroll.BackgroundTransparency = 1
            ItemScroll.ScrollBarThickness = 2
            ItemScroll.ScrollBarImageColor3 = Theme.AccentColor
            ItemScroll.ZIndex = 101
            ItemScroll.CanvasSize = UDim2.new(0, 0, 0, 0)
            ItemScroll.AutomaticCanvasSize = Enum.AutomaticSize.Y
            
            local ItemLayout = Instance.new("UIListLayout", ItemScroll)
            ItemLayout.Padding = UDim.new(0, 4)
            ItemLayout.SortOrder = Enum.SortOrder.LayoutOrder

            local isOpen = false

            local function UpdateSelectedText()
                if #SelectedItems == 0 then
                    SelectedDisplay.Text = "None"
                else
                    SelectedDisplay.Text = table.concat(SelectedItems, ", ")
                end
            end

            local ItemButtons = {}

            local function RefreshList(filter)
                for _, btn in ipairs(ItemButtons) do btn:Destroy() end
                table.clear(ItemButtons)

                for _, itemStr in ipairs(DropList) do
                    if not filter or filter == "" or string.find(string.lower(itemStr), string.lower(filter)) then
                        local ItemBtn = Instance.new("TextButton", ItemScroll)
                        ItemBtn.Size = UDim2.new(1, -10, 0, 30)
                        ItemBtn.BackgroundColor3 = Theme.DropdownItemBg
                        ItemBtn.Text = ""
                        ItemBtn.AutoButtonColor = false
                        ItemBtn.ZIndex = 102
                        Instance.new("UICorner", ItemBtn).CornerRadius = UDim.new(0, 6)

                        local isSelected = table.find(SelectedItems, itemStr) ~= nil
                        if isSelected then
                            ItemBtn.BackgroundColor3 = Theme.DropdownSelected
                        end

                        local ItemTxt = Instance.new("TextLabel", ItemBtn)
                        ItemTxt.Size = UDim2.new(1, -20, 1, 0)
                        ItemTxt.Position = UDim2.new(0, 10, 0, 0)
                        ItemTxt.BackgroundTransparency = 1
                        ItemTxt.Text = itemStr
                        ItemTxt.TextColor3 = isSelected and Theme.AccentColor or Theme.TextColor
                        ItemTxt.Font = Enum.Font.GothamMedium
                        ItemTxt.TextSize = 12
                        ItemTxt.TextXAlignment = Enum.TextXAlignment.Left
                        ItemTxt.ZIndex = 102

                        ItemBtn.MouseButton1Click:Connect(function()
                            local idx = table.find(SelectedItems, itemStr)
                            
                            if idx then
                                -- إزالة التحديد
                                table.remove(SelectedItems, idx)
                            else
                                -- إضافة التحديد بناءً على العدد الأقصى
                                if MaxSelect == 1 then
                                    SelectedItems = {itemStr} -- استبدال كلي
                                    isOpen = false
                                    OverlayFrame.Visible = false
                                    TweenService:Create(DropArrow, TweenInfo.new(0.2), {Rotation = 0}):Play()
                                else
                                    if #SelectedItems < MaxSelect then
                                        table.insert(SelectedItems, itemStr)
                                    end
                                end
                            end
                            
                            UpdateSelectedText()
                            RefreshList(SearchBox.Text)
                            Callback(MaxSelect == 1 and SelectedItems[1] or SelectedItems)
                        end)

                        table.insert(ItemButtons, ItemBtn)
                    end
                end
            end

            SearchBox.Changed:Connect(function(prop)
                if prop == "Text" then RefreshList(SearchBox.Text) end
            end)

            DropBtn.MouseButton1Click:Connect(function()
                isOpen = not isOpen
                if isOpen then
                    -- حساب الموقع الديناميكي ليكون فوق كل شيء وبجانب الزر
                    local absPos = DropBtn.AbsolutePosition
                    local absSize = DropBtn.AbsoluteSize
                    
                    -- تحسين موقع العرض بناءً على حجم الشاشة
                    local viewSize = workspace.CurrentCamera.ViewportSize
                    local dropY = absPos.Y + absSize.Y + 5
                    if dropY + 200 > viewSize.Y then
                        dropY = absPos.Y - 205 -- يفتح للأعلى إذا كان قريباً من الحافة
                    end

                    OverlayFrame.Position = UDim2.new(0, absPos.X, 0, dropY)
                    OverlayFrame.Size = UDim2.new(0, absSize.X, 0, 200)
                    RefreshList()
                    
                    OverlayFrame.Visible = true
                    TweenService:Create(DropArrow, TweenInfo.new(0.2), {Rotation = 180}):Play()
                else
                    OverlayFrame.Visible = false
                    TweenService:Create(DropArrow, TweenInfo.new(0.2), {Rotation = 0}):Play()
                end
            end)
            
            -- إخفاء القائمة عند الضغط خارجها يتم إدارته برمجياً عادة، للتبسيط هنا تغلق من الزر.
        end

        return TabData
    end

    return WindowData
end

return ThunderUI
